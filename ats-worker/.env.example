# Copy to .env and fill in. Loaded by ats_worker.run.load_env.

# Anthropic API key — used only for the tailoring step (Claude writes the LaTeX).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Telegram bot credentials for the human-in-the-loop alert + PDF.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPQRstuVWxyz
TELEGRAM_CHAT_ID=123456789

# Ollama endpoint used for scoring (no cost, no rate limits).
#   - bare metal / local run:  http://localhost:11434
#   - Docker (Ollama on the HOST, using the GPU): http://host.docker.internal:11434
#     (docker-compose maps host.docker.internal via extra_hosts on Linux)
OLLAMA_HOST=http://host.docker.internal:11434
