.cursor
*.db
*.tar
__pycache__
logs/
db/
screenshots/

# Per-user secrets & config. The repo ships ONLY *.example templates; each user
# copies them to the real filename (which stays gitignored), so no personal data
# — resume, target companies, API keys, chat id — is ever committed/pushed.
apps/worker/.env
apps/worker/.venv
apps/worker/config.yaml
# Ignore the CONTENTS of resume/ (not the dir itself, so the re-includes below
# work — a dir-level ignore would suppress them).
apps/worker/resume/*
!apps/worker/resume/README.md
!apps/worker/resume/master.tex.example
!apps/worker/resume/resume.txt.example
resumes/
